[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=8 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_rebound"]
script = ExtResource("2")
kind = "force_defensive_rebound"
target_id = "PG"

[sub_resource type="Resource" id="ScenarioAction_wait"]
script = ExtResource("2")
kind = "wait"
seconds = 4.3

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="ScenarioExpectation_log"]
script = ExtResource("3")
kind = "log_contains"
value = "Defensive rebound"

[resource]
script = ExtResource("1")
scenario_id = "contested_miss_defensive_rebound"
display_name = "Contested Miss With Defensive Rebound"
seed = 102
setup = {
"ballhandler_role": "RW",
"defense_positions": {
"LC": Vector2(470, 700),
"LW": Vector2(500, 650),
"PG": Vector2(540, 600),
"RC": Vector2(580, 650),
"RW": Vector2(610, 700)
},
"offense_positions": {
"LC": Vector2(250, 780),
"LW": Vector2(360, 980),
"PG": Vector2(520, 1260),
"RC": Vector2(760, 980),
"RW": Vector2(540, 760)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_rebound"), SubResource("ScenarioAction_wait")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_log")])
tags = PackedStringArray("scenario", "rebound", "defense")
