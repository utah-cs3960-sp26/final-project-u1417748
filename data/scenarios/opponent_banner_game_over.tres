[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=7 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="Action_force_sim"]
script = ExtResource("2")
kind = "force_opponent_sim_result"
value = {
"action_count": 1,
"points_scored": 2,
"time_consumed": 5.0
}

[sub_resource type="Resource" id="Action_wait"]
script = ExtResource("2")
kind = "wait"
seconds = 1.2

[sub_resource type="Resource" id="Expectation_state"]
script = ExtResource("3")
kind = "state"
value = "GAME_OVER"

[sub_resource type="Resource" id="Expectation_score"]
script = ExtResource("3")
kind = "away_score"
value = 2

[resource]
script = ExtResource("1")
scenario_id = "opponent_banner_game_over"
display_name = "Opponent Banner Game Over"
seed = 205
initial_time_remaining = 2.0
initial_away_score = 0
actions = Array[ExtResource("2")]([SubResource("Action_force_sim"), SubResource("Action_wait")])
expectations = Array[ExtResource("3")]([SubResource("Expectation_state"), SubResource("Expectation_score")])
tags = PackedStringArray("scenario", "opponent_sim", "banner", "game_over")
