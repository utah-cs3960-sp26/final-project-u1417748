[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=8 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_wait"]
script = ExtResource("2")
kind = "force_pressure_turnover"

[sub_resource type="Resource" id="ScenarioAction_wait_resolve"]
script = ExtResource("2")
kind = "wait"
seconds = 0.4

[sub_resource type="Resource" id="ScenarioExpectation_log"]
script = ExtResource("3")
kind = "log_contains"
value = "Pressure turnover"

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="ScenarioExpectation_role"]
script = ExtResource("3")
kind = "controlled_role"
value = "PG"

[resource]
script = ExtResource("1")
scenario_id = "stationary_pressure_turnover"
display_name = "Stationary Pressure Turnover"
seed = 103
setup = {
"ballhandler_role": "PG",
"defense_positions": {
"LC": Vector2(320, 720),
"LW": Vector2(360, 980),
"PG": Vector2(548, 1188),
"RC": Vector2(720, 720),
"RW": Vector2(720, 980)
},
"offense_positions": {
"LC": Vector2(260, 760),
"LW": Vector2(360, 1040),
"PG": Vector2(540, 1250),
"RC": Vector2(760, 760),
"RW": Vector2(720, 1040)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_wait"), SubResource("ScenarioAction_wait_resolve")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_log"), SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_role")])
tags = PackedStringArray("scenario", "turnover", "pressure")
