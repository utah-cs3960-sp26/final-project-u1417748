[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=9 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_hold_green"]
script = ExtResource("2")
kind = "hold_until_meter_quality"
seconds = 2.0
value = "green"

[sub_resource type="Resource" id="ScenarioAction_release"]
script = ExtResource("2")
kind = "release"

[sub_resource type="Resource" id="ScenarioAction_wait_resolve"]
script = ExtResource("2")
kind = "wait"
seconds = 12.0

[sub_resource type="Resource" id="ScenarioExpectation_score"]
script = ExtResource("3")
kind = "home_score"
value = 2

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="ScenarioExpectation_log"]
script = ExtResource("3")
kind = "log_contains"
value = "Shot released green make"

[resource]
script = ExtResource("1")
scenario_id = "contested_green_release_scores"
display_name = "Contested Green Release Scores"
seed = 108
setup = {
"ballhandler_role": "RC",
"defense_positions": {
"LC": Vector2(300, 620),
"LW": Vector2(360, 980),
"PG": Vector2(520, 1320),
"RC": Vector2(582, 782),
"RW": Vector2(760, 980)
},
"offense_positions": {
"LC": Vector2(260, 680),
"LW": Vector2(360, 1040),
"PG": Vector2(520, 1360),
"RC": Vector2(560, 760),
"RW": Vector2(720, 1040)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_hold_green"), SubResource("ScenarioAction_release"), SubResource("ScenarioAction_wait_resolve")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_score"), SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_log")])
tags = PackedStringArray("scenario", "shot", "green", "contest")
