[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=9 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_force_score"]
script = ExtResource("2")
kind = "force_scoring_shot"
target_id = "RC"
value = 2

[sub_resource type="Resource" id="ScenarioAction_wait"]
script = ExtResource("2")
kind = "wait"
seconds = 2.8

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "GAME_OVER"

[sub_resource type="Resource" id="ScenarioExpectation_score"]
script = ExtResource("3")
kind = "home_score"
value = 2

[sub_resource type="Resource" id="ScenarioExpectation_through_net"]
script = ExtResource("3")
kind = "through_net_score"
value = true

[resource]
script = ExtResource("1")
scenario_id = "buzzer_shot_completion"
display_name = "Buzzer Shot Completion"
seed = 105
initial_time_remaining = 0.05
setup = {
"ballhandler_role": "RC",
"offense_positions": {
"RC": Vector2(560, 760)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_force_score"), SubResource("ScenarioAction_wait")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_score"), SubResource("ScenarioExpectation_through_net")])
tags = PackedStringArray("scenario", "buzzer", "score")
