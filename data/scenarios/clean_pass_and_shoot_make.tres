[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=11 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_pass"]
script = ExtResource("2")
kind = "release_pass"
target_id = "RC"

[sub_resource type="Resource" id="ScenarioAction_wait_catch"]
script = ExtResource("2")
kind = "wait"
seconds = 0.95

[sub_resource type="Resource" id="ScenarioAction_assert_control"]
script = ExtResource("2")
kind = "assert_controlled_player"
target_id = "RC"

[sub_resource type="Resource" id="ScenarioAction_assert_log"]
script = ExtResource("2")
kind = "assert_last_log_contains"
value = "Pass caught by"

[sub_resource type="Resource" id="ScenarioAction_force_score"]
script = ExtResource("2")
kind = "force_scoring_shot"
target_id = "RC"
value = 2

[sub_resource type="Resource" id="ScenarioAction_wait_resolve"]
script = ExtResource("2")
kind = "wait"
seconds = 7.0

[sub_resource type="Resource" id="ScenarioExpectation_score"]
script = ExtResource("3")
kind = "home_score"
value = 2

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="ScenarioExpectation_log"]
script = ExtResource("3")
kind = "log_contains"
value = "Score 2 points"

[sub_resource type="Resource" id="ScenarioExpectation_through_net"]
script = ExtResource("3")
kind = "through_net_score"
value = true

[resource]
script = ExtResource("1")
scenario_id = "clean_pass_and_shoot_make"
display_name = "Clean Pass And Shoot Make"
seed = 101
setup = {
"ballhandler_role": "PG",
"defense_positions": {
"LC": Vector2(300, 620),
"LW": Vector2(300, 1060),
"PG": Vector2(320, 1460),
"RC": Vector2(830, 640),
"RW": Vector2(800, 1060)
},
"offense_positions": {
"LC": Vector2(260, 640),
"LW": Vector2(360, 1040),
"PG": Vector2(520, 1360),
"RC": Vector2(620, 900),
"RW": Vector2(740, 1100)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_pass"), SubResource("ScenarioAction_wait_catch"), SubResource("ScenarioAction_assert_control"), SubResource("ScenarioAction_assert_log"), SubResource("ScenarioAction_force_score"), SubResource("ScenarioAction_wait_resolve")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_score"), SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_log"), SubResource("ScenarioExpectation_through_net")])
tags = PackedStringArray("scenario", "pass", "score")
