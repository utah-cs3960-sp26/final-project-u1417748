[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=10 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="Action_force_sim"]
script = ExtResource("2")
kind = "force_opponent_sim_result"
value = {
"action_count": 4,
"points_scored": 2,
"time_consumed": 6.0
}

[sub_resource type="Resource" id="Action_tap_1"]
script = ExtResource("2")
kind = "tap_opponent_banner"

[sub_resource type="Resource" id="Action_tap_2"]
script = ExtResource("2")
kind = "tap_opponent_banner"

[sub_resource type="Resource" id="Action_tap_3"]
script = ExtResource("2")
kind = "tap_opponent_banner"

[sub_resource type="Resource" id="Action_tap_4"]
script = ExtResource("2")
kind = "tap_opponent_banner"

[sub_resource type="Resource" id="Expectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="Expectation_score"]
script = ExtResource("3")
kind = "away_score"
value = 2

[resource]
script = ExtResource("1")
scenario_id = "opponent_banner_tap_skip"
display_name = "Opponent Banner Tap Skip"
seed = 204
initial_away_score = 0
actions = Array[ExtResource("2")]([SubResource("Action_force_sim"), SubResource("Action_tap_1"), SubResource("Action_tap_2"), SubResource("Action_tap_3"), SubResource("Action_tap_4")])
expectations = Array[ExtResource("3")]([SubResource("Expectation_state"), SubResource("Expectation_score")])
tags = PackedStringArray("scenario", "opponent_sim", "banner", "tap")
