[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=8 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_pass"]
script = ExtResource("2")
kind = "release_pass"
target_id = "RC"

[sub_resource type="Resource" id="ScenarioAction_wait"]
script = ExtResource("2")
kind = "wait"
seconds = 0.18

[sub_resource type="Resource" id="ScenarioAction_force_intercept"]
script = ExtResource("2")
kind = "force_pass_interception"

[sub_resource type="Resource" id="ScenarioAction_wait_steal"]
script = ExtResource("2")
kind = "wait"
seconds = 0.9

[sub_resource type="Resource" id="ScenarioAction_wait_resolve"]
script = ExtResource("2")
kind = "wait"
seconds = 1.8

[sub_resource type="Resource" id="ScenarioExpectation_log"]
script = ExtResource("3")
kind = "log_contains"
value = "Pass intercepted"

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="ScenarioExpectation_feedback"]
script = ExtResource("3")
kind = "feedback_contains"
value = "STEAL!"

[resource]
script = ExtResource("1")
scenario_id = "bad_cross_court_pass_steal"
display_name = "Bad Cross Court Pass Steal"
seed = 11
setup = {
"ballhandler_role": "PG",
"defense_positions": {
"LC": Vector2(400, 930),
"LW": Vector2(560, 1080),
"PG": Vector2(320, 1380),
"RC": Vector2(820, 720),
"RW": Vector2(700, 920)
},
"offense_positions": {
"LC": Vector2(250, 800),
"LW": Vector2(340, 1040),
"PG": Vector2(250, 1460),
"RC": Vector2(840, 700),
"RW": Vector2(660, 1060)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_pass"), SubResource("ScenarioAction_wait"), SubResource("ScenarioAction_force_intercept"), SubResource("ScenarioAction_wait_steal"), SubResource("ScenarioAction_wait_resolve")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_log"), SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_feedback")])
tags = PackedStringArray("scenario", "pass", "steal")
