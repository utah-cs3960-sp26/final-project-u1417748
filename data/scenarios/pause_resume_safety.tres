[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=9 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_pause"]
script = ExtResource("2")
kind = "pause_toggle"

[sub_resource type="Resource" id="ScenarioAction_wait_pause"]
script = ExtResource("2")
kind = "wait"
seconds = 0.4

[sub_resource type="Resource" id="ScenarioAction_resume"]
script = ExtResource("2")
kind = "pause_toggle"

[sub_resource type="Resource" id="ScenarioAction_wait_live"]
script = ExtResource("2")
kind = "wait"
seconds = 0.2

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="ScenarioExpectation_clock"]
script = ExtResource("3")
kind = "clock_at_least"
value = 179.6

[resource]
script = ExtResource("1")
scenario_id = "pause_resume_safety"
display_name = "Pause Resume Safety"
seed = 106
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_pause"), SubResource("ScenarioAction_wait_pause"), SubResource("ScenarioAction_resume"), SubResource("ScenarioAction_wait_live")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_clock")])
tags = PackedStringArray("scenario", "pause", "safety")
