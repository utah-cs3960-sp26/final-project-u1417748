[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=9 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_rebound"]
script = ExtResource("2")
kind = "force_offensive_rebound"
target_id = "LC"

[sub_resource type="Resource" id="ScenarioAction_wait"]
script = ExtResource("2")
kind = "wait"
seconds = 0.4

[sub_resource type="Resource" id="ScenarioExpectation_log"]
script = ExtResource("3")
kind = "log_contains"
value = "Offensive rebound"

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[sub_resource type="Resource" id="ScenarioExpectation_role"]
script = ExtResource("3")
kind = "controlled_role"
value = "LC"

[resource]
script = ExtResource("1")
scenario_id = "offensive_rebound_continuation"
display_name = "Offensive Rebound Continuation"
seed = 4
setup = {
"ballhandler_role": "PG",
"defense_positions": {
"LC": Vector2(780, 540),
"LW": Vector2(770, 760),
"PG": Vector2(740, 1180),
"RC": Vector2(830, 540),
"RW": Vector2(830, 760)
},
"offense_positions": {
"LC": Vector2(300, 650),
"LW": Vector2(360, 960),
"PG": Vector2(540, 1320),
"RC": Vector2(620, 680),
"RW": Vector2(700, 980)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_rebound"), SubResource("ScenarioAction_wait")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_log"), SubResource("ScenarioExpectation_state"), SubResource("ScenarioExpectation_role")])
tags = PackedStringArray("scenario", "rebound", "offense")
