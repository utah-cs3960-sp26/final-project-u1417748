[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=11 format=3]

[ext_resource type="Script" path="res://tests/harness/ScenarioDefinition.gd" id="1"]
[ext_resource type="Script" path="res://tests/harness/ScenarioAction.gd" id="2"]
[ext_resource type="Script" path="res://tests/harness/ScenarioExpectation.gd" id="3"]

[sub_resource type="Resource" id="ScenarioAction_arm"]
script = ExtResource("2")
kind = "arm_shot"

[sub_resource type="Resource" id="ScenarioAction_wait_timeout"]
script = ExtResource("2")
kind = "wait"
seconds = 1.9

[sub_resource type="Resource" id="ScenarioAction_force_def_rebound"]
script = ExtResource("2")
kind = "force_defensive_rebound"
target_id = "RC"

[sub_resource type="Resource" id="ScenarioAction_wait_finish"]
script = ExtResource("2")
kind = "wait"
seconds = 0.3

[sub_resource type="Resource" id="ScenarioExpectation_log"]
script = ExtResource("3")
kind = "log_contains"
value = "Shot timing expired late"

[sub_resource type="Resource" id="ScenarioExpectation_state"]
script = ExtResource("3")
kind = "state"
value = "LIVE_OFFENSE"

[resource]
script = ExtResource("1")
scenario_id = "late_miss_timeout"
display_name = "Late Miss Timeout"
seed = 109
setup = {
"ballhandler_role": "RC",
"defense_positions": {
"LC": Vector2(300, 620),
"LW": Vector2(360, 980),
"PG": Vector2(520, 1320),
"RC": Vector2(582, 782),
"RW": Vector2(760, 980)
},
"offense_positions": {
"LC": Vector2(260, 680),
"LW": Vector2(360, 1040),
"PG": Vector2(520, 1360),
"RC": Vector2(560, 760),
"RW": Vector2(720, 1040)
}
}
actions = Array[ExtResource("2")]([SubResource("ScenarioAction_arm"), SubResource("ScenarioAction_wait_timeout"), SubResource("ScenarioAction_force_def_rebound"), SubResource("ScenarioAction_wait_finish")])
expectations = Array[ExtResource("3")]([SubResource("ScenarioExpectation_log"), SubResource("ScenarioExpectation_state")])
tags = PackedStringArray("scenario", "shot", "late")
