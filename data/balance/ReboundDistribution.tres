[gd_resource type="Resource" script_class="BalanceBatchDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/debug/BalanceBatchDefinition.gd" id="1"]

[resource]
script = ExtResource("1")
batch_id = "rebound_distribution"
title = "Rebound Distribution"
description = "Batch placeholder for repeated missed shots, measuring offensive vs defensive rebound share and positional influence."
seed = 496005
iterations = 300
scenario_id = "offensive_rebound_continuation"
metrics = PackedStringArray("offensive_rebound_rate", "defensive_rebound_rate", "center_rebound_share")
thresholds = {"defensive_rebound_rate_min": 0.45, "offensive_rebound_rate_max": 0.45}
